{
  "name": "m6800-vasm-std",
  "displayName": "M6800 Assembly vam6800 standard syntax",
  "description": "Syntax Highlighting for 6800 Assembly (vasm6800_std)",
  "version": "0.0.1",
  "publisher": "crankery",
  "icon": "logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/crankery/m6800_std"
  },
  "engines": {
    "vscode": "^1.34.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [
  ],
  "contributes": {
    "keybindings": [
      {
        "command": "m6800-as0.as0assemble",
        "key": "ctrl-shift-m",
        "mac": "cmd-m",
        "when": "editorTextFocus"
      }
    ],
    "commands": [
    ],
    "languages": [
      {
        "id": "m6800-as0",
        "aliases": [
          "6800 Assembly (vasm6800_std)",
          "m6800-vasm-std"
        ],
        "extensions": [
          ".asm",
          ".s",
          ".list",
          ".out",
          ".lst"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "m6800-vasm-std",
        "scopeName": "source.m6800-vasm-std",
        "path": "./syntaxes/m6800-vasm-std.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "6800 Assembly Syntax Highlighting (vasm6800_std) configuration",
      "properties": {
      }
    }
  }
}
